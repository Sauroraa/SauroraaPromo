# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
APP_URL=https://promoteam.sauroraa.be
FRONTEND_URL=https://promoteam.sauroraa.be
PORT=5000
TRUST_PROXY=2
RATE_LIMIT_GLOBAL_WINDOW_MS=900000
RATE_LIMIT_GLOBAL_MAX=600
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=12
RATE_LIMIT_UPLOAD_WINDOW_MS=86400000
RATE_LIMIT_UPLOAD_MAX=120
RATE_LIMIT_PROOF_WINDOW_MS=3600000
RATE_LIMIT_PROOF_MAX=30

# ─── Database ─────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_PASSWORD=change_me_db
DB_HOST=mariadb
DB_PORT=3306
DB_USER=promoteam
DB_NAME=promoteam

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_with_a_long_random_secret_at_least_64_chars

# ─── Mail (SMTP) ──────────────────────────────────────────────────────────────
MAIL_HOST=smtp.us.appsuite.cloud
MAIL_PORT=587
MAIL_USER=contact@sauroraa.be
MAIL_PASSWORD=your_smtp_password_here
MAIL_FROM="Promoteam <contact@sauroraa.be>"

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=https://promoteam.sauroraa.be/api
VITE_APP_URL=https://promoteam.sauroraa.be

# ─── Admin seed (used by: node scripts/seed-admin.js) ────────────────────────
ADMIN_EMAIL=admin@promoteam.sauroraa.be
ADMIN_PASSWORD=Admin2024!
